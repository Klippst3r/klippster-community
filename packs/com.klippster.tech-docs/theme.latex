\definecolor{accent}{RGB}{13,110,90}
\definecolor{shadecolor}{RGB}{240,242,244}
\providecommand{\tightlist}{\setlength{\itemsep}{0pt}\setlength{\parskip}{0pt}}
$highlighting-macros$
\makeatletter
\@ifundefined{Shaded}{\newenvironment{Shaded}{\begin{snugshade}}{\end{snugshade}}}{\renewenvironment{Shaded}{\begin{snugshade}}{\end{snugshade}}}
\makeatother
\setcounter{secnumdepth}{0}
\titleformat{\section}{\bfseries\Large\color{accent}}{}{0em}{}
\titleformat{\subsection}{\bfseries\large\color{accent}}{}{0em}{}
\titlespacing*{\section}{0pt}{1.3em}{0.4em}
\hypersetup{colorlinks=true,linkcolor=accent,urlcolor=accent}
\pagestyle{fancy}\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
