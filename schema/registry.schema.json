{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schema.klippster.app/v1/registry.json",
  "title": "Klippster pack registry index",
  "description": "The registry.json index the Klippster app fetches to discover installable packs. Generated from the packs/ tree by scripts/build_registry.py.",
  "type": "object",
  "required": ["schemaVersion", "registrySerial", "packs"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "registrySerial": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonic anti-rollback counter, advanced on each signed release. Clients refuse an index whose serial is lower than the highest they have already trusted."
    },
    "packs": {
      "type": "array",
      "items": { "$ref": "#/definitions/pack" }
    }
  },
  "definitions": {
    "pack": {
      "type": "object",
      "required": ["id", "name", "version", "provider", "inputs", "outputs", "path", "files"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "license": { "type": "string" },
        "provider": { "type": "string", "enum": ["native", "host", "template", "wasm"] },
        "inputs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "outputs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "path": { "type": "string", "pattern": "^packs/" },
        "preview": {
          "type": "string",
          "format": "uri",
          "description": "Optional URL of a rendered thumbnail (previews/<id>/sample.png), produced by the preview CI for PDF theme packs. Not part of the signed per-file checksums."
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "sha256", "url"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    }
  }
}
