{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schema.klippster.app/v1/klippster.json",
  "title": "Klippster pack manifest",
  "description": "A single converter/provider a Klippster pack contributes. File name: klippster.json.",
  "type": "object",
  "required": ["id", "name", "version", "inputs", "outputs", "provider"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "minLength": 1, "description": "Stable unique id, e.g. github-markdown." },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "author": { "type": "string" },
    "license": { "type": "string" },
    "description": { "type": "string" },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Content types accepted (extension / MIME / UTI / alias)."
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Content types produced."
    },
    "provider": {
      "type": "string",
      "enum": ["native", "host", "template", "wasm"],
      "description": "Execution model."
    },
    "engine": { "type": "string", "description": "Engine name for native/template providers." },
    "binary": { "type": "string", "description": "Binary name for the host provider (e.g. pandoc)." },
    "module": { "type": "string", "description": "WASM module filename for the wasm provider." },
    "options": {
      "type": "object",
      "description": "Engine-specific options. For template/pandoc: from, to, wrap (allowlisted).",
      "additionalProperties": { "type": "string" }
    },
    "permissions": { "type": "array", "items": { "type": "string" } }
  },
  "allOf": [
    {
      "if": { "properties": { "provider": { "enum": ["native", "template"] } } },
      "then": { "required": ["engine"] }
    },
    {
      "if": { "properties": { "provider": { "const": "host" } } },
      "then": { "required": ["binary"] }
    },
    {
      "if": { "properties": { "provider": { "const": "wasm" } } },
      "then": { "required": ["module"] }
    }
  ]
}
